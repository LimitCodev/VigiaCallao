# ── ML — Detección YOLO ────────────────────────────────────────
VIDEO_SOURCE=./test_video/demo.mp4
YOLO_MODEL=yolo26n.pt
# YOLO_MODEL=yolo11n.pt   <- descomentar si yolo26n falla (fallback)
DETECTION_CONFIDENCE=0.45
PARKING_THRESHOLD_SECONDS=30
RESTRICTED_ZONE=100,200,800,600
PROCESSING_FPS=10

# ── Backend ────────────────────────────────────────────────────
ALERT_ENDPOINT=http://localhost:5000/api/alerts
ML_API_KEY=CAMBIAR_POR_CLAVE_INTERNA_SEGURA

# ── Base de datos ──────────────────────────────────────────────
USE_ORACLE=False
DB_HOST=tu_host.oraclecloud.com
DB_PORT=1521
DB_SERVICE_NAME=tu_service_name
DB_USER=tu_usuario
DB_PASSWORD=tu_password

# ── Frontend Expo ──────────────────────────────────────────────
EXPO_PUBLIC_BACKEND_URL=http://localhost:5000
EXPO_PUBLIC_SOCKET_URL=http://localhost:5000
